# ===========================================
# ITCareerMatch Frontend - Environment Config
# ===========================================
# Salin file ini ke .env untuk development
# JANGAN commit file .env ke repository!
# ===========================================

# --- API Configuration ---
# URL backend API (Express.js)
VITE_API_BASE_URL=http://localhost:3000

# --- Supabase Configuration ---
# Dapatkan nilai ini dari dashboard Supabase project Anda
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Application Configuration ---
VITE_APP_NAME=ITCareerMatch
VITE_APP_ENV=development

# --- Optional: Feature Flags ---
# Aktifkan/nonaktifkan fitur tertentu
# VITE_FEATURE_CHATBOT=true
# VITE_FEATURE_CV_EDITOR=false